{
  "name": "rentnest-backend",
  "version": "1.0.0",
  "description": "Backend for RentNest application",
  "main": "src/server.ts",
  "engines": {
    "node": "18.x"
  },
  "scripts": {
    "start": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "prisma generate && tsc",
    "lint": "eslint src --ext .ts",
    "seed": "ts-node prisma/seed.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "@prisma/adapter-pg": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "http-status": "^1.6.0",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.11.0",
    "stripe": "^12.0.0",
    "zod": "^3.21.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.0.0",
    "prisma": "^5.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}